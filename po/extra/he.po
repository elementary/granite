#~ msgid "Make tab tooltips of DynamicNotebook settable"
#~ msgstr "חלוניות העצה של הלשוניות של DynamicNotebook הפכו לניתנות להגדרה"

#~ msgid ""
#~ "Timepicker correctly fires time_changed when AM and PM buttons are "
